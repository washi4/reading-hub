---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readingStats } from '../../lib/reading-stats';

export async function getStaticPaths() {
	const posts = await getCollection('posts');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post, allPosts: posts },
	}));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const source = post.data.source;
const ytMatch = source?.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]{11})/);
const youtubeId = ytMatch?.[1];
const cover = post.data.cover ?? (youtubeId ? `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg` : undefined);

const chunks = post.data.chunks ?? [];
const typeLabels: Record<string, string> = {
	chunk: '语块',
	collocation: '搭配',
	formulaic: '惯用话语',
	'sentence-frame': '句式框架',
};

const { minutes, totalWords } = readingStats(post.body ?? '');

// TOC: only h2 / h3, drop the article title if it's the first h1
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

// Prev / next by date descending (same ordering as index)
const sorted = [...allPosts].sort((a, b) => {
	const ad = a.data.date?.getTime() ?? 0;
	const bd = b.data.date?.getTime() ?? 0;
	return bd - ad;
});
const idx = sorted.findIndex((p) => p.id === post.id);
const newer = idx > 0 ? sorted[idx - 1] : undefined;
const older = idx >= 0 && idx < sorted.length - 1 ? sorted[idx + 1] : undefined;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');

// Source card bits (favicon + host + optional date)
let sourceHost: string | undefined;
let sourceFavicon: string | undefined;
if (source) {
	try {
		const u = new URL(source);
		sourceHost = u.hostname.replace(/^www\./, '');
		sourceFavicon = `https://www.google.com/s2/favicons?sz=64&domain=${u.hostname}`;
	} catch {}
}

const ogImage = cover;
---

<BaseLayout title={`${post.data.title} | Reading Hub`} description={post.data.description} image={ogImage} type="article">
	<article class={tocHeadings.length >= 3 ? 'has-toc' : undefined}>
		<header class="article-header">
			<h1>{post.data.title}</h1>
			<div class="post-meta">
				{post.data.date && (
					<time datetime={post.data.date.toISOString()}>{dateFormatter.format(post.data.date)}</time>
				)}
				<span class="meta-dot" aria-hidden="true">·</span>
				<span class="reading-time">{minutes} min read</span>
				<span class="meta-dot" aria-hidden="true">·</span>
				<span class="word-count">{totalWords.toLocaleString()} words</span>
			</div>
			{post.data.tags.length > 0 && (
				<div class="tags" aria-label="文章标签">
					{post.data.tags.map((tag) => (
						<a class="tag tag-link" href={`${baseUrl}tags/${encodeURIComponent(tag)}/`}>#{tag}</a>
					))}
				</div>
			)}
			{cover && (
				<a class="post-cover" href={source} target="_blank" rel="noopener noreferrer">
					<img src={cover} alt={post.data.title} loading="lazy" />
					{youtubeId && <span class="post-cover-badge">▶ 在 YouTube 观看原视频</span>}
				</a>
			)}
			{source && !youtubeId && sourceHost && (
				<a class="source-card" href={source} target="_blank" rel="noopener noreferrer">
					{sourceFavicon && <img class="source-card-icon" src={sourceFavicon} alt="" width="32" height="32" loading="lazy" />}
					<span class="source-card-body">
						<span class="source-card-label">阅读原文</span>
						<span class="source-card-host">{sourceHost}</span>
					</span>
					<span class="source-card-arrow" aria-hidden="true">→</span>
				</a>
			)}
			{post.data.description && (
				<aside class="tldr" aria-label="本文摘要">
					<span class="tldr-label">In Brief</span>
					<p>{post.data.description}</p>
				</aside>
			)}
		</header>

		{tocHeadings.length >= 3 && (
			<details class="toc" open>
				<summary>
					<span class="toc-label">On this page</span>
					<span class="toc-chevron" aria-hidden="true">▾</span>
				</summary>
				<ol>
					{tocHeadings.map((h) => (
						<li class={`toc-depth-${h.depth}`}>
							<a href={`#${h.slug}`}>{h.text}</a>
						</li>
					))}
				</ol>
			</details>
		)}

		<div class="article-body" data-chunks={chunks.length > 0 ? JSON.stringify(chunks) : undefined}>
			<Content />
		</div>
		{chunks.length > 0 && (
			<aside class="chunks-panel" aria-label="本文语块">
				<h2>📘 本文语块 <span class="chunks-count">{chunks.length}</span></h2>
				<p class="chunks-hint">正文里的黄色高亮就是下面这些表达，鼠标悬停或点击可看中文含义。</p>
				<ul class="chunks-legend" aria-label="类型图例">
					{Object.entries(typeLabels).map(([k, v]) => (
						<li><span class={`chunks-type chunks-type-${k}`}>{v}</span></li>
					))}
				</ul>
				<ul class="chunks-list">
					{chunks.map((c) => (
						<li>
							<span class="chunks-text">{c.text}</span>
							{c.type && <span class={`chunks-type chunks-type-${c.type}`}>{typeLabels[c.type] ?? c.type}</span>}
							<span class="chunks-meaning">{c.meaning}</span>
							{c.note && <span class="chunks-note">{c.note}</span>}
						</li>
					))}
				</ul>
			</aside>
		)}

		{(newer || older) && (
			<nav class="post-nav" aria-label="上一篇 / 下一篇">
				{older ? (
					<a class="post-nav-link post-nav-prev" href={`${baseUrl}posts/${older.id}/`}>
						<span class="post-nav-dir">← 上一篇</span>
						<span class="post-nav-title">{older.data.title}</span>
					</a>
				) : <span />}
				{newer ? (
					<a class="post-nav-link post-nav-next" href={`${baseUrl}posts/${newer.id}/`}>
						<span class="post-nav-dir">下一篇 →</span>
						<span class="post-nav-title">{newer.data.title}</span>
					</a>
				) : <span />}
			</nav>
		)}
	</article>
</BaseLayout>

<script>
	// Walk text nodes inside .article-body and wrap matches for each chunk.
	// Client-side so we don't need a remark plugin.
	const body = document.querySelector<HTMLElement>('.article-body[data-chunks]');
	if (body) {
		const raw = body.getAttribute('data-chunks');
		if (raw) {
			type Chunk = { text: string; meaning: string; type?: string; note?: string };
			const chunks: Chunk[] = JSON.parse(raw);
			// Longest first so "play it safe" beats "play it".
			chunks.sort((a, b) => b.text.length - a.text.length);

			const escapeRe = (s: string) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
			const seen = new Set<string>();
			const typeLabels: Record<string, string> = {
				chunk: '语块',
				collocation: '搭配',
				formulaic: '惯用话语',
				'sentence-frame': '句式框架',
			};

			const walk = (node: Node) => {
				if (node.nodeType === Node.TEXT_NODE) {
					const text = node.textContent ?? '';
					for (const chunk of chunks) {
						const re = new RegExp(escapeRe(chunk.text), 'i');
						const match = re.exec(text);
						if (!match) continue;

						const before = text.slice(0, match.index);
						const hit = text.slice(match.index, match.index + match[0].length);
						const after = text.slice(match.index + match[0].length);

						const mark = document.createElement('mark');
						mark.className = 'chunk-highlight';
						mark.textContent = hit;

						// Structured tooltip with meaning + type + note so mobile tap shows the same detail as desktop hover.
						const tip = document.createElement('span');
						tip.className = 'chunk-tooltip';
						const meaningEl = document.createElement('span');
						meaningEl.className = 'chunk-tooltip-meaning';
						meaningEl.textContent = chunk.meaning;
						tip.appendChild(meaningEl);
						if (chunk.type && typeLabels[chunk.type]) {
							const typeEl = document.createElement('span');
							typeEl.className = `chunk-tooltip-type chunk-tooltip-type-${chunk.type}`;
							typeEl.textContent = typeLabels[chunk.type];
							tip.appendChild(typeEl);
						}
						if (chunk.note) {
							const noteEl = document.createElement('span');
							noteEl.className = 'chunk-tooltip-note';
							noteEl.textContent = chunk.note;
							tip.appendChild(noteEl);
						}
						mark.appendChild(tip);
						// Only highlight the first occurrence to avoid noisy pages.
						if (seen.has(chunk.text.toLowerCase())) continue;
						seen.add(chunk.text.toLowerCase());

						const parent = node.parentNode!;
						if (before) parent.insertBefore(document.createTextNode(before), node);
						parent.insertBefore(mark, node);
						const tail = document.createTextNode(after);
						parent.insertBefore(tail, node);
						parent.removeChild(node);
						walk(tail);
						return;
					}
					return;
				}
				if (
					node.nodeType === Node.ELEMENT_NODE &&
					!['SCRIPT', 'STYLE', 'CODE', 'PRE', 'MARK'].includes((node as Element).tagName) &&
					!(node as Element).classList.contains('chunk-tooltip')
				) {
					Array.from(node.childNodes).forEach(walk);
				}
			};
			walk(body);

			// Tap-to-toggle on mobile where :hover doesn't exist.
			// Clicking anywhere else (including another highlight) closes the open one.
			document.addEventListener('click', (e) => {
				const t = e.target as HTMLElement | null;
				const hit = t?.closest('.chunk-highlight') as HTMLElement | null;
				document.querySelectorAll('.chunk-highlight.chunk-open').forEach((el) => {
					if (el !== hit) {
						el.classList.remove('chunk-open');
						const tip = el.querySelector('.chunk-tooltip') as HTMLElement | null;
						if (tip) tip.style.removeProperty('transform');
					}
				});
				if (hit) {
					// Only toggle when the mark itself is tapped —
					// taps inside the tooltip box just keep it open.
					if (!t?.closest('.chunk-tooltip')) {
						const isOpening = !hit.classList.contains('chunk-open');
						hit.classList.toggle('chunk-open');

						if (isOpening) {
							// After the browser has laid out the newly-visible tooltip,
							// nudge its transform so it stays fully inside the viewport.
							requestAnimationFrame(() => {
								const tip = hit.querySelector('.chunk-tooltip') as HTMLElement | null;
								if (!tip) return;
								const rect = tip.getBoundingClientRect();
								const vw = window.innerWidth;
								const PAD = 8;
								if (rect.left < PAD) {
									const shift = PAD - rect.left;
									tip.style.transform = `translateX(calc(-50% + ${shift}px))`;
								} else if (rect.right > vw - PAD) {
									const shift = rect.right - (vw - PAD);
									tip.style.transform = `translateX(calc(-50% - ${shift}px))`;
								}
							});
						}
					}
				}
			});
		}
	}
</script>

<script>
	// TOC scroll-spy: highlight the link whose heading is closest to the top of the viewport.
	const toc = document.querySelector<HTMLDetailsElement>('.toc');
	if (toc) {
		// Default-collapsed on narrow screens so it doesn't dominate the top of the post.
		if (window.matchMedia('(max-width: 48rem)').matches) {
			toc.open = false;
		}
		const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>('a[href^="#"]'));
		const entries = links
			.map((a) => {
				const id = decodeURIComponent(a.getAttribute('href')!.slice(1));
				const el = document.getElementById(id);
				return el ? { link: a, el } : null;
			})
			.filter((x): x is { link: HTMLAnchorElement; el: HTMLElement } => !!x);

		const setActive = (link: HTMLAnchorElement | null) => {
			for (const { link: a } of entries) a.classList.remove('toc-active');
			link?.classList.add('toc-active');
		};

		// Activation line sits just below the sticky header. The topmost
		// heading above that line wins. If none is above, fall back to the first.
		const header = document.querySelector<HTMLElement>('.site-header');
		const update = () => {
			const headerH = header?.getBoundingClientRect().height ?? 0;
			const line = headerH + 24;
			let current: HTMLAnchorElement | null = entries[0]?.link ?? null;
			for (const { link, el } of entries) {
				const top = el.getBoundingClientRect().top;
				if (top <= line) current = link;
				else break;
			}
			setActive(current);
		};

		let ticking = false;
		const onScroll = () => {
			if (ticking) return;
			ticking = true;
			requestAnimationFrame(() => {
				update();
				ticking = false;
			});
		};
		window.addEventListener('scroll', onScroll, { passive: true });
		window.addEventListener('resize', onScroll);
		update();

		// Click: set active immediately so it doesn't wait for scroll settle.
		for (const { link } of entries) {
			link.addEventListener('click', () => setActive(link));
		}
	}
</script>