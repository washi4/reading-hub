---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { readingStats } from '../lib/reading-stats';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => {
	const da = a.data.date?.getTime() ?? 0;
	const db = b.data.date?.getTime() ?? 0;
	return db - da;
});

const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const stats = new Map(
	sortedPosts.map((p) => [p.id, readingStats(p.body ?? '')]),
);

const tagCounts = new Map<string, number>();
for (const p of sortedPosts) {
	for (const t of p.data.tags ?? []) {
		tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
	}
}
const tagList = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title="Reading Hub | 文章列表" description="个人阅读站：按时间倒序整理中英混合文章。">
	<section>
		<div class="index-header">
			<h1>Reading Hub</h1>
			{tagList.length > 0 && (
				<button type="button" class="tag-toggle" aria-expanded="false" aria-controls="index-tag-cloud" title="按标签筛选">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18M6 12h12M10 18h4"/></svg>
					<span class="sr-only">按标签筛选</span>
				</button>
			)}
		</div>
		<p>
			这里记录我想反复阅读的内容：文章、转录稿、实验笔记，以及中英混合的长文摘录。
			页面保持简洁，适合安静地读完一篇。
		</p>
		{tagList.length > 0 && (
			<ul id="index-tag-cloud" class="tag-cloud index-tag-cloud" hidden>
				{tagList.map(([tag, count]) => (
					<li>
						<a class="tag tag-link" href={`${baseUrl}tags/${encodeURIComponent(tag)}/`}>
							#{tag}<span class="tag-count">{count}</span>
						</a>
					</li>
				))}
			</ul>
		)}

		<ul class="posts-list">
			{
				sortedPosts.map((post) => {
					const s = stats.get(post.id)!;
					const chunkCount = post.data.chunks?.length ?? 0;
					return (
						<li class="post-card">
							<h2 class="post-card-title">
								<a href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}posts/${post.id}/`}>{post.data.title}</a>
							</h2>
							<div class="post-meta">
								{post.data.date && (
									<time datetime={post.data.date.toISOString()}>{dateFormatter.format(post.data.date)}</time>
								)}
								<span class="meta-dot" aria-hidden="true">·</span>
								<span>{s.minutes} min read</span>
								{chunkCount > 0 && (
									<>
										<span class="meta-dot" aria-hidden="true">·</span>
										<span>📘 {chunkCount} 语块</span>
									</>
								)}
							</div>
							{post.data.description && <p class="post-description">{post.data.description}</p>}
							{post.data.tags.length > 0 && (
								<div class="tags" aria-label="文章标签">
									{post.data.tags.map((tag) => (
										<a class="tag tag-link" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}tags/${encodeURIComponent(tag)}/`}>#{tag}</a>
									))}
								</div>
							)}
						</li>
					);
				})
			}
		</ul>
	</section>
</BaseLayout>

<script is:inline>
	(() => {
		const btn = document.querySelector('.tag-toggle');
		const cloud = document.getElementById('index-tag-cloud');
		if (!btn || !cloud) return;
		btn.addEventListener('click', () => {
			const open = cloud.hasAttribute('hidden') ? true : false;
			if (open) {
				cloud.removeAttribute('hidden');
				btn.setAttribute('aria-expanded', 'true');
				btn.classList.add('is-open');
			} else {
				cloud.setAttribute('hidden', '');
				btn.setAttribute('aria-expanded', 'false');
				btn.classList.remove('is-open');
			}
		});
	})();
</script>
