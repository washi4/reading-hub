---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Reading Hub',
	description = 'A calm space for bilingual long-form reading.',
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl.replace(/\/?$/, '/')}favicon.svg`} />
		<title>{title}</title>
		<script is:inline>
			(() => {
				const KEY = 'reading-hub-theme';
				const saved = localStorage.getItem(KEY);
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const resolved = saved === 'light' || saved === 'dark' ? saved : prefersDark ? 'dark' : 'light';
				document.documentElement.setAttribute('data-theme', resolved);
			})();
		</script>
	</head>
	<body>
		<div class="shell">
			<header class="site-header">
				<div class="site-header-inner">
					<a class="site-title" href={baseUrl}>Reading Hub</a>
					<ThemeToggle />
				</div>
			</header>
			<main>
				<div class="content-wrap">
					<slot />
				</div>
			</main>
			<footer class="site-footer">
				Quiet reading for mixed Chinese &amp; English notes.
			</footer>
		</div>
		<button type="button" class="back-to-top" aria-label="回到顶部" hidden>
			<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
		</button>
		<script is:inline>
			(() => {
				const btn = document.querySelector('.back-to-top');
				if (!btn) return;
				const onScroll = () => {
					if (window.scrollY > window.innerHeight * 0.6) btn.hidden = false;
					else btn.hidden = true;
				};
				window.addEventListener('scroll', onScroll, { passive: true });
				btn.addEventListener('click', () => {
					const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
					window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
				});
				onScroll();
			})();
		</script>
	</body>
</html>
